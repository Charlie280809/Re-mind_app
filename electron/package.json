{
    "name": "electron",
    "version": "1.0.0",
    "description": "",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "build": "npm --prefix ../frontend run build && electron-builder"
    },
    "build": {
        "appId": "com.remind.app",
        "productName": "Re-Mind",
        "extraResources": [
            {
                "from": "../frontend/dist",
                "to": "renderer"
            },
            {
                "from": "../backend",
                "to": "backend",
                "filter": [
                    "**/*",
                    "!**/node_modules/.cache/**"
                ]
            }
        ],
        "win": {
            "icon": "assets/favicon.ico"
        }
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "devDependencies": {
        "electron": "^41.1.1",
        "electron-builder": "^26.8.1"
    }
}